ALTITUDE=0:1000:20000;
LATITUDE=-90:10:90;
[ALTITUDE,LATITUDE]=MESHGRID(ALTITUDE,LATITUDE);
TEMPERATURE=SIN(ALTITUDE)+COS(LATITUDE);
SURF(ALTITUDE,LATITUDE,TEMPERATURE);
XLABEL('ALTITUDE(M)');
YLABEL('LATITUDE(CIRC)');
ZLABEL('TEMPERATURE(CIRC)');
TITLE('ATMOSPHERIC TEMPERTAURE DISTRIBUTION');
COLORBAR;
